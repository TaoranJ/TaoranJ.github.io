author = {Khandpur, Rupinder Paul and Ji, Taoran and Jan, Steve and Wang, Gang and Lu, Chang-Tien and Ramakrishnan, Naren},
title = {Crowdsourcing Cybersecurity: Cyber Attack Detection using Social Media},
year = {2017},
